{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./", 
    "incremental": true,
    "skipLibCheck": true,
    "strict": true, // 👈 CRÍTICO: Ativa todas as verificações de tipo estritas
    "strictNullChecks": true, 
    "noImplicitAny": true, 

    "paths": {
      "@/*": ["src/*"] 
    }
  },
  "exclude": ["node_modules", "dist"]
}